{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SOURCE_FIRMWARE": "ON",
        "BUILD_WEEK2_EXAMPLES": "OFF"
      }
    },
    {
      "name": "with-week2",
      "displayName": "Default + Week2",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/with-week2",
      "cacheVariables": {
        "BUILD_WEEK2_EXAMPLES": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "with-week2",
      "configurePreset": "with-week2"
    }
  ]
}
